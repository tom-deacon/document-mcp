# Example environment configuration for MCP Document Indexer

# Folders to monitor (comma-separated)
WATCH_FOLDERS="/Users/me/Documents,/Users/me/Research"

# LanceDB storage path
LANCEDB_PATH="./vector_index"

# Ollama model for summarization
LLM_MODEL="llama3.2:3b"

# Text chunking settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Embedding model (sentence-transformers)
EMBEDDING_MODEL="all-MiniLM-L6-v2"

# File types to index (comma-separated) — xlsx/xls added for Excel support
FILE_EXTENSIONS=".pdf,.docx,.doc,.txt,.md,.rtf,.xlsx,.xls"

# Maximum file size in MB
MAX_FILE_SIZE_MB=100

# Ollama API URL
OLLAMA_BASE_URL="http://localhost:11434"

# Batch size for processing
BATCH_SIZE=10

# ---- Structured parsing (new in v0.2) ----
# Set false to revert to original plain-text chunking for all file types
USE_STRUCTURED_PARSING=true
# Target token budget per chunk in structured mode (256–800 typical)
MAX_CHUNK_TOKENS=512