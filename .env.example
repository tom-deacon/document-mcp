# Example environment configuration for MCP Document Indexer

# Folders to monitor (comma-separated)
WATCH_FOLDERS="/Users/me/Documents,/Users/me/Research"

# LanceDB storage path
LANCEDB_PATH="./vector_index"

# Ollama model for summarization
LLM_MODEL="llama3.2:3b"

# Text chunking settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Embedding model (sentence-transformers)
EMBEDDING_MODEL="all-MiniLM-L6-v2"

# File types to index (comma-separated) — xlsx/xls added for Excel support
FILE_EXTENSIONS=".pdf,.docx,.doc,.txt,.md,.rtf,.xlsx,.xls"

# Maximum file size in MB
MAX_FILE_SIZE_MB=100

# Ollama API URL
OLLAMA_BASE_URL="http://localhost:11434"

# Batch size for processing
BATCH_SIZE=10

# ---- Structured parsing (new in v0.2) ----
# Set false to revert to original plain-text chunking for all file types
USE_STRUCTURED_PARSING=true
# Target token budget per chunk in structured mode (256–800 typical)
MAX_CHUNK_TOKENS=512

# ---- Visual ingestion (new in v0.2) ----
# Run EasyOCR on images embedded in DOCX/PDF files.
# Requires: pip install easyocr  (no external binary needed)
ENABLE_OCR=true
# Language code (Tesseract-style). Default 'eng' (English).
OCR_LANGUAGE=eng
# Optional: send images to a vision-capable Ollama model for a description.
# Set ENABLE_VISION_SUMMARY=true and provide a model such as llava:7b.
ENABLE_VISION_SUMMARY=false
VISION_MODEL=

# ---- Anthropic vision enhancement (new in v0.3) ----
# For PDF pages with fewer than VISION_WORD_THRESHOLD words, rasterise the page
# and call the Anthropic Claude vision API to generate a structured description.
# Requires the 'anthropic' package (uv add anthropic) and ANTHROPIC_API_KEY.
ENABLE_VISION_ENHANCEMENT=false
VISION_WORD_THRESHOLD=50
# Your Anthropic API key — read by the anthropic SDK automatically.
ANTHROPIC_API_KEY=